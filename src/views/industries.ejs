<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Industries We Serve - Greymatter Accountancy</title>
  <link rel="stylesheet" href="../css/styles.css">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Sora:wght@400;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
  <%- include('partials/header', { rootPath: '../', currentPage: 'page' }) %>

  <section class="page-header page-header-light">
    <div class="container">
      <h1>Industries We Serve</h1>
      <p>Support for a broad mix of businesses and working styles.</p>
    </div>
  </section>

  <section class="industries industries-page">
    <div class="container">
      
      <div class="industries-grid">
        <div class="industry-card">
          <div class="industry-icon"><i class="fas fa-building"></i></div>
          <h3>Property & Construction</h3>
          <p>Property records, project costs, and practical reporting</p>
        </div>
        <div class="industry-card">
          <div class="industry-icon"><i class="fas fa-gavel"></i></div>
          <h3>Professional Services</h3>
          <p>Advisory firms, consultants, and specialist practices</p>
        </div>
        <div class="industry-card">
          <div class="industry-icon"><i class="fas fa-palette"></i></div>
          <h3>Creative & Media</h3>
          <p>Project work, retainers, and creative operations</p>
        </div>
        <div class="industry-card">
          <div class="industry-icon"><i class="fas fa-shopping-cart"></i></div>
          <h3>Retail & Hospitality</h3>
          <p>Sales records, stock flow, and operational finance</p>
        </div>
        <div class="industry-card">
          <div class="industry-icon"><i class="fas fa-laptop-code"></i></div>
          <h3>Tech & Startups</h3>
          <p>Growing teams, reporting rhythm, and investor conversations</p>
        </div>
      </div>
      <div class="industry-testimonial">
        <p class="quote">
          "They understand how our business works — not just the ledger."
        </p>
        <p class="quote-author">— Client testimonial</p>
      </div>
    </div>
  </section>

  <section class="cta-section">
    <div class="container">
      <h2>Want Sector-Aware Advice?</h2>
      <p>Tell us what you do, and we'll shape the accounting around how your business works.</p>
      <a href="../index.html#contact" class="btn btn-primary">Discuss Your Business</a>
    </div>
  </section>
  <%- include('partials/footer', { rootPath: '../', currentPage: 'page' }) %>
</body>
</html>
