<%
  const pathPrefix = typeof rootPath !== 'undefined' ? rootPath : '';
  const isHome = currentPage === 'home';
  const homeHref = isHome ? '#' : `${pathPrefix}index.html`;
  const servicesHref = isHome ? 'pages/services.html' : 'services.html';
  const industriesHref = isHome ? 'pages/industries.html' : 'industries.html';
  const contactHref = isHome ? '#contact' : `${pathPrefix}index.html#contact`;
%>
  <!-- Navigation -->
  <nav class="navbar">
    <div class="container">
      <div class="navbar-content">
        <a class="logo" href="<%= homeHref %>" aria-label="Greymatter home">
          <div class="logo-icon"><i class="fas fa-chart-line"></i></div>
          <span class="logo-text">Greymatter</span>
        </a>
        <ul class="nav-links">
          <li><a href="<%= servicesHref %>">Services</a></li>
          <li><a href="<%= industriesHref %>">Industries</a></li>
          <li><a href="<%= isHome ? 'pages/about.html' : 'about.html' %>">About</a></li>
          <li><a href="<%= isHome ? 'pages/team.html' : 'team.html' %>">Team</a></li>
          <li><a href="<%= isHome ? 'pages/pricing.html' : 'pricing.html' %>">Pricing</a></li>
          <li><a href="<%= isHome ? 'pages/resources.html' : 'resources.html' %>">Resources</a></li>
          <li><a href="<%= contactHref %>" class="nav-cta">Contact</a></li>
        </ul>
        <div class="hamburger" id="hamburger">
          <span></span>
          <span></span>
          <span></span>
        </div>
      </div>
    </div>
  </nav>
