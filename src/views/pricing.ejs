<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Pricing - Greymatter Accountancy</title>
  <link rel="stylesheet" href="../css/styles.css">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Sora:wght@400;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
  <%- include('partials/header', { rootPath: '../', currentPage: 'page' }) %>

  <section class="page-header">
    <div class="container">
      <h1>Transparent Pricing</h1>
      <p>No surprises. No lock-in contracts.</p>
    </div>
  </section>

  <section class="pricing pricing-page">
    <div class="container">
      <div class="section-header">
        <h2>Transparent Pricing</h2>
        <p>No surprises. No lock-in contracts.</p>
      </div>
      <div class="pricing-cards">
        <div class="pricing-card">
          <h3>Essentials</h3>
          <p class="price">From <span>£195</span>/month</p>
          <ul class="features">
            <li>✓ Bookkeeping</li>
            <li>✓ VAT Management</li>
            <li>✓ Quarterly review</li>
            <li>✓ Email support</li>
          </ul>
          <a href="../index.html#contact" class="btn btn-secondary">Get Started</a>
        </div>
        <div class="pricing-card pricing-card-featured">
          <div class="featured-badge">Most Popular</div>
          <h3>Pro</h3>
          <p class="price">From <span>£395</span>/month</p>
          <ul class="features">
            <li>✓ Everything in Essentials</li>
            <li>✓ Management Accounts</li>
            <li>✓ Year-end Accounts</li>
            <li>✓ Tax Planning</li>
            <li>✓ Priority support</li>
          </ul>
          <a href="../index.html#contact" class="btn btn-primary">Get Started</a>
        </div>
        <div class="pricing-card">
          <h3>Audit & Assurance</h3>
          <p class="price">Custom Quote</p>
          <ul class="features">
            <li>✓ Full statutory audit</li>
            <li>✓ Risk assessment</li>
            <li>✓ Stakeholder reports</li>
            <li>✓ Strategic advice</li>
          </ul>
          <a href="../index.html#contact" class="btn btn-secondary">Request Quote</a>
        </div>
      </div>
      <p class="pricing-note">30 days notice to upgrade or cancel. No surprises.</p>
    </div>
  </section>

  <section class="cta-section">
    <div class="container">
      <h2>Ready to Get Started?</h2>
      <p>Let's have a free call to discuss which package fits your business.</p>
      <a href="../index.html#contact" class="btn btn-primary">Book a Free Consultation</a>
    </div>
  </section>
  <%- include('partials/footer', { rootPath: '../', currentPage: 'page' }) %>
</body>
</html>
