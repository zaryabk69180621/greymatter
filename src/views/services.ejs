<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Services - Greymatter Accountancy</title>
  <link rel="stylesheet" href="../css/styles.css">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link
    href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Sora:wght@400;600;700&display=swap"
    rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>

<body>
  <%- include('partials/header', { rootPath: '../' , currentPage: 'page' }) %>

    <section class="page-header page-header-light">
      <div class="container">
        <h1>Our Core Services</h1>
        <p>Complete financial solutions tailored to your needs</p>
      </div>
    </section>

    <section class="services services-page">
      <div class="container">

        <div class="services-grid">
          <a href="personal-tax.html" class="service-card">
            <div class="service-icon"><i class="fas fa-user-tie"></i></div>
            <h3>Personal Tax</h3>
            <p>Tailored tax planning, filling and advice to protect and optimise your personal wealth. We manage Sole
              traders Accounts, Property rental accounts, and Locum accounts.</p>

            <span class="service-link">Learn more <i class="fas fa-arrow-right"></i></span>
          </a>
          <a href="business-compliance.html" class="service-card">
            <div class="service-icon"><i class="fas fa-building-columns"></i></div>
            <h3>Business Compliance</h3>
            <p>Your complete back-office finance team. Bookkeeping, statutory accounts, payroll & pensions,
              MTD-compliant VAT returns, Corporation Tax, and company secretarial support.</p>
            <span class="service-link">Learn more <i class="fas fa-arrow-right"></i></span>
          </a>
          <a href="software-solutions.html" class="service-card">
            <div class="service-icon"><i class="fas fa-laptop-code"></i></div>
            <h3>Software Solutions</h3>
            <p>Modern cloud accounting setups. Dedicated QuickBooks setup, training, and seamless data migrations from
              Excel to Cloud Accounting Software to streamline your workflows.</p>
            <span class="service-link">Learn more <i class="fas fa-arrow-right"></i></span>
          </a>
        </div>
      </div>
    </section>

    <section class="cta-section">
      <div class="container">
        <h2>Need Help Choosing the Right Services?</h2>
        <p>Let's discuss your requirements in a free consultation.</p>
        <a href="../index.html#contact" class="btn btn-primary">Get in Touch</a>
      </div>
    </section>
    <%- include('partials/footer', { rootPath: '../' , currentPage: 'page' }) %>
</body>

</html>