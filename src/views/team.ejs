<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Our Team - Greymatter Accountancy</title>
  <link rel="stylesheet" href="../css/styles.css">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Sora:wght@400;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
  <%- include('partials/header', { rootPath: '../', currentPage: 'page' }) %>

  <section class="page-header page-header-light">
    <div class="container">
      <h1>Meet the Team</h1>
      <p>Experienced professionals who care about your success</p>
    </div>
  </section>

  <section class="team team-page">
    <div class="container">
     
      <div class="team-grid">
        <div class="team-member">
          <div class="member-avatar">SO</div>
          <h3>Sarah Okonkwo</h3>
          <p class="role">Managing Director</p>
          <p class="bio">Leads client relationships with a focus on clear reporting, practical advice, and calm financial decision-making.</p>
        </div>
        <div class="team-member">
          <div class="member-avatar">JV</div>
          <h3>James Varghese</h3>
          <p class="role">Audit & Assurance Lead</p>
          <p class="bio">Guides assurance work with a careful eye for controls, documentation, and dependable reporting habits.</p>
        </div>
        <div class="team-member">
          <div class="member-avatar">ER</div>
          <h3>Elena Rossi</h3>
          <p class="role">Tax & Compliance Specialist</p>
          <p class="bio">Supports tax and compliance planning with plain-English guidance and a steady approach to deadlines.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="cta-section">
    <div class="container">
      <h2>Ready to Work with Our Team?</h2>
      <p>Let's connect you with the right specialist for your accounting needs.</p>
      <a href="../index.html#contact" class="btn btn-primary">Get in Touch</a>
    </div>
  </section>
  <%- include('partials/footer', { rootPath: '../', currentPage: 'page' }) %>
</body>
</html>
